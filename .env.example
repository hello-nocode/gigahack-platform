# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google (dev)
#                          https://portal.gigahack.md/api/auth/callback/google (prod)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Database ──────────────────────────────────────────────────────────────────
# Neon: https://neon.tech/  |  Local: postgresql://user:pass@localhost:5432/gigahack
DATABASE_URL=

# ── SMTP (magic link email) ───────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@gigahack.md

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
